# Python cache and build artifacts
__pycache__/
*.py[cod]
*.pyo
*.so
*.dylib
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/
ENV/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.nox/
.tox/
.ipynb_checkpoints/

# IDE/editor
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Local datasets and generated experiment artifacts
data/
results/

# Keep optional placeholders if needed
!data/.gitkeep
!results/.gitkeep

# Ignore local toolbox clone entirely
backdoor-toolbox-main/

# Jupyter and temp files
*.ipynb
*.tmp
*.temp

# Keep relevant source and orchestration files tracked by default
# (scripts/, src/, docs, configs, and root metadata stay versioned)
